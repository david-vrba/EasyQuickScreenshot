# Build output
/target
settings-app/target
settings-app/gen
*.exe
*.pdb

# Screenshots must NEVER be committed — this is the whole point.
/shots
*.png
*.png.tmp
*.jpg
*.jpeg
*.bmp
# ...but brand/UI assets are part of the source and must be committed.
!assets/**
!settings-app/icons/**
!settings-app/ui/**

# Local user config (commit config.example.toml instead)
/config.toml

# Private launch/marketing working notes — never publish these to the public repo.
/promo/

# Secrets & credentials — must NEVER be committed (none exist today; this is a safety net)
.env
.env.*
*.pem
*.key
*.pfx
*.p12
secrets.*
*.secret

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# OS junk
Thumbs.db
Desktop.ini
.DS_Store

# Misc
*.log
Cargo.lock.orig
